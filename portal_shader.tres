code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded;

uniform vec4 Portal_Color_ring : source_color;
uniform sampler2D tex_frg_18;
uniform vec4 Portal_Color : source_color;
uniform sampler2D tex_frg_8 : source_color;
uniform sampler2D tex_frg_2 : source_color;
uniform sampler2D tex_frg_23;
uniform sampler2D tex_frg_25;
uniform sampler2D tex_frg_7;



void fragment() {
// ColorParameter:22
	vec4 n_out22p0 = Portal_Color_ring;


// Texture2D:18
	vec4 n_out18p0 = texture(tex_frg_18, UV);
	float n_out18p1 = n_out18p0.r;


// VectorOp:21
	vec4 n_out21p0 = n_out22p0 * vec4(n_out18p1);


// ColorParameter:14
	vec4 n_out14p0 = Portal_Color;


	vec2 n_out3p0;
// UVPolarCoord:3
	vec2 n_in3p1 = vec2(0.50000, 0.50000);
	float n_in3p2 = 1.68000;
	float n_in3p3 = 1.00000;
	{
		vec2 __dir = UV - n_in3p1;
		float __radius = length(__dir) * 2.0;
		float __angle = atan(__dir.y, __dir.x) * 1.0 / (PI * 2.0);
		n_out3p0 = vec2(__radius * n_in3p2, __angle * n_in3p3);
	}


// Input:5
	float n_out5p0 = TIME;


// MultiplyAdd:6
	vec2 n_in6p1 = vec2(-0.30000, 0.30000);
	vec2 n_in6p2 = vec2(0.00000, 0.00000);
	vec2 n_out6p0 = fma(vec2(n_out5p0), n_in6p1, n_in6p2);


// UVFunc:4
	vec2 n_in4p1 = vec2(1.00000, 1.00000);
	vec2 n_out4p0 = n_out6p0 * n_in4p1 + n_out3p0;


// Texture2D:8
	vec4 n_out8p0 = texture(tex_frg_8, n_out4p0);
	float n_out8p1 = n_out8p0.r;


// VectorOp:15
	vec4 n_out15p0 = n_out14p0 * vec4(n_out8p1);


// ColorConstant:17
	vec4 n_out17p0 = vec4(5.397585, 5.359175, 5.743275, 1.000000);


	vec2 n_out11p0;
// UVPolarCoord:11
	vec2 n_in11p1 = vec2(0.50000, 0.50000);
	float n_in11p2 = 1.68000;
	float n_in11p3 = 1.00000;
	{
		vec2 __dir = UV - n_in11p1;
		float __radius = length(__dir) * 2.0;
		float __angle = atan(__dir.y, __dir.x) * 1.0 / (PI * 2.0);
		n_out11p0 = vec2(__radius * n_in11p2, __angle * n_in11p3);
	}


// Input:12
	float n_out12p0 = TIME;


// MultiplyAdd:13
	vec2 n_in13p1 = vec2(-0.50000, 0.50000);
	vec2 n_in13p2 = vec2(0.00000, 0.00000);
	vec2 n_out13p0 = fma(vec2(n_out12p0), n_in13p1, n_in13p2);


// UVFunc:10
	vec2 n_in10p1 = vec2(1.00000, 1.00000);
	vec2 n_out10p0 = n_out13p0 * n_in10p1 + n_out11p0;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out10p0);
	float n_out2p1 = n_out2p0.r;


// MultiplyAdd:9
	float n_in9p0 = 0.00000;
	float n_in9p1 = 1.00000;
	float n_out9p0 = fma(n_in9p0, n_in9p1, n_out2p1);


// MultiplyAdd:16
	vec4 n_out16p0 = fma(n_out15p0, n_out17p0, vec4(n_out9p0));


// MultiplyAdd:19
	vec3 n_in19p1 = vec3(1.00000, 1.00000, 1.00000);
	vec3 n_out19p0 = fma(vec3(n_out21p0.xyz), n_in19p1, vec3(n_out16p0.xyz));


// Texture2D:23
	vec4 n_out23p0 = texture(tex_frg_23, UV);
	float n_out23p1 = n_out23p0.r;


	vec2 n_out30p0;
// UVPolarCoord:30
	vec2 n_in30p1 = vec2(0.50000, 0.50000);
	float n_in30p2 = 1.70500;
	float n_in30p3 = 1.00000;
	{
		vec2 __dir = UV - n_in30p1;
		float __radius = length(__dir) * 2.0;
		float __angle = atan(__dir.y, __dir.x) * 1.0 / (PI * 2.0);
		n_out30p0 = vec2(__radius * n_in30p2, __angle * n_in30p3);
	}


// Input:28
	float n_out28p0 = TIME;


// MultiplyAdd:29
	vec2 n_in29p1 = vec2(-0.30000, 0.30000);
	vec2 n_in29p2 = vec2(0.00000, 0.00000);
	vec2 n_out29p0 = fma(vec2(n_out28p0), n_in29p1, n_in29p2);


// UVFunc:27
	vec2 n_in27p1 = vec2(1.00000, 1.00000);
	vec2 n_out27p0 = n_out29p0 * n_in27p1 + n_out30p0;


// Texture2D:25
	vec4 n_out25p0 = texture(tex_frg_25, n_out27p0);
	float n_out25p1 = n_out25p0.r;


// FloatOp:26
	float n_out26p0 = min(n_out23p1, n_out25p1);


// Texture2D:7
	vec4 n_out7p0 = texture(tex_frg_7, UV);
	float n_out7p1 = n_out7p0.r;


// FloatOp:24
	float n_out24p0 = n_out26p0 + n_out7p1;


// Output:0
	ALBEDO = n_out19p0;
	ALPHA = n_out24p0;


}
