[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded;

uniform vec2 speed;
uniform vec2 Scale = vec2(1.000000, 1.000000);
uniform sampler2D texturabase : source_color, repeat_enable;
uniform vec2 speed2;
uniform vec2 Scale2 = vec2(1.000000, 1.000000);
uniform sampler2D texturabase2 : source_color, repeat_enable;
uniform sampler2D texturaagregad : source_color, hint_default_black, repeat_enable;
uniform sampler2D Substractinfo : source_color, hint_default_black, repeat_enable;
uniform sampler2D color : source_color, hint_default_black, repeat_enable;



void fragment() {
// Vector2Parameter:5
	vec2 n_out5p0 = speed;


// Input:7
	float n_out7p0 = TIME;


// VectorOp:8
	vec3 n_out8p0 = vec3(n_out5p0, 0.0) * vec3(n_out7p0);


// Vector2Parameter:10
	vec2 n_out10p0 = Scale;


// UVFunc:9
	vec2 n_in9p2 = vec2(0.00000, 0.00000);
	vec2 n_out9p0 = (vec2(n_out8p0.xy) - n_in9p2) * n_out10p0 + n_in9p2;


// UVFunc:6
	vec2 n_in6p1 = vec2(1.00000, 1.00000);
	vec2 n_out6p0 = n_out9p0 * n_in6p1 + UV;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(texturabase, n_out6p0);


// Vector2Parameter:24
	vec2 n_out24p0 = speed2;


// Input:26
	float n_out26p0 = TIME;


// VectorOp:25
	vec3 n_out25p0 = vec3(n_out24p0, 0.0) * vec3(n_out26p0);


// Vector2Parameter:27
	vec2 n_out27p0 = Scale2;


// UVFunc:28
	vec2 n_in28p2 = vec2(0.00000, 0.00000);
	vec2 n_out28p0 = (vec2(n_out25p0.xy) - n_in28p2) * n_out27p0 + n_in28p2;


// UVFunc:22
	vec2 n_in22p1 = vec2(1.00000, 1.00000);
	vec2 n_out22p0 = n_out28p0 * n_in22p1 + UV;


	vec4 n_out29p0;
// Texture2D:29
	n_out29p0 = texture(texturabase2, n_out22p0);


// FloatOp:21
	float n_out21p0 = n_out3p0.x + n_out29p0.x;


	vec4 n_out13p0;
// Texture2D:13
	n_out13p0 = texture(texturaagregad, UV);


// FloatOp:14
	float n_out14p0 = n_out21p0 + n_out13p0.x;


	vec4 n_out16p0;
// Texture2D:16
	n_out16p0 = texture(Substractinfo, UV);


// FloatOp:17
	float n_out17p0 = n_out14p0 - n_out16p0.x;


// Clamp:18
	float n_in18p1 = 0.00000;
	float n_in18p2 = 1.00000;
	float n_out18p0 = clamp(n_out17p0, n_in18p1, n_in18p2);


	vec4 n_out20p0;
// Texture2D:20
	n_out20p0 = texture(color, vec2(n_out18p0));


// Output:0
	ALBEDO = vec3(n_out20p0.xyz);
	ALPHA = n_out18p0;


}
"
